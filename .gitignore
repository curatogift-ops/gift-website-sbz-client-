# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# production
/dist

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files (can opt-in for committing if needed)
.env*

# vercel
.vercel

# typescript
*.tsbuildinfo

# Large catalogue PDFs — extracted from catalogue-bundles/ during npm run build
public/catalogues/*.pdf
public/catalogues/*.pptx
!public/catalogues/README.md
# Keep zip bundles tracked so Vercel can extract them at build time
!catalogue-bundles/*.zip
